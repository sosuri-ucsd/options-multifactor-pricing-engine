# Copy to .env and fill in real values. Never commit .env.

# polygon.io — Options Starter/Developer tier. Chains, reference data, historical OHLC.
POLYGON_API_KEY=your_polygon_api_key_here

# tradier.com — sandbox account. Market-data IV/Greeks cross-check + paper-trading broker.
TRADIER_API_KEY=your_tradier_api_key_here
TRADIER_ACCOUNT_ID=your_tradier_account_id_here

# fred.stlouisfed.org — free API key. Used for DGS3MO (3-month Treasury yield).
FRED_API_KEY=your_fred_api_key_here

# Optional: Slack incoming webhook URL for alerting on unhandled exceptions
# and risk-limit breaches (deployment/alerting.py). If unset, alerts are
# only written to the log file, not sent anywhere.
ALERT_SLACK_WEBHOOK_URL=
